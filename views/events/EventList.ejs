<%- include('../partials/header') %>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-calendar-event me-2"></i>All Events</h2>
        <% if (currentUser && (currentUser.role==='Organizer' || currentUser.role==='Admin' )) { %>
            <a href="/events/new" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Add Event
            </a>
            <% } %>
    </div>

    <!-- Search Form -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form action="/events" method="GET" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Search by Event Name</label>
                    <input type="text" class="form-control" name="search" placeholder="e.g. Tech Conference"
                        value="<%= search %>" />
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Search by Venue</label>
                    <input type="text" class="form-control" name="venue" placeholder="e.g. Lahore"
                        value="<%= venue %>" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                </div>
            </form>
            <% if (search || venue) { %>
                <a href="/events" class="btn btn-sm btn-outline-secondary mt-2">
                    <i class="bi bi-x-circle me-1"></i>Clear
                </a>
                <% } %>
        </div>
    </div>

    <!-- Events Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <% if (events.length===0) { %>
                <p class="text-muted p-4 mb-0">No events found.</p>
                <% } else { %>
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-primary">
                            <tr>
                                <th>#</th>
                                <th>Event Name</th>
                                <th>Date</th>
                                <th>Venue</th>
                                <th>Organizer</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% events.forEach((event, i)=> { %>
                                <% const isPast=new Date(event.eventDate) < new Date(); %>
                                    <tr class="<%= isPast ? 'table-secondary' : '' %>">
                                        <td>
                                            <%= (currentPage - 1) * limit + i + 1 %>
                                        </td>
                                        <td>
                                            <strong>
                                                <%= event.eventName %>
                                            </strong>
                                            <!-- #10 past badge -->
                                            <% if (isPast) { %>
                                                <span class="badge bg-secondary ms-1">Past</span>
                                                <% } %>
                                        </td>
                                        <td>
                                            <%= new Date(event.eventDate).toLocaleDateString('en-US', {
                                                dateStyle: 'medium' }) %>
                                        </td>
                                        <td>
                                            <%= event.venue %>
                                        </td>
                                        <td>
                                            <%= event.organizer ? event.organizer.username : 'N/A' %>
                                        </td>
                                        <td>
                                            <a href="/events/<%= event._id %>"
                                                class="btn btn-sm btn-outline-primary me-1">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <% const isAdminU=currentUser && currentUser.role==='Admin' ; const
                                                isOrganizerU=currentUser && currentUser.role==='Organizer' ; const
                                                isOwnerU=currentUser && event.organizer &&
                                                event.organizer._id.toString()===currentUser._id.toString(); %>
                                                <% if (isAdminU || (isOrganizerU && isOwnerU)) { %>
                                                    <a href="/events/<%= event._id %>/edit"
                                                        class="btn btn-sm btn-outline-warning me-1">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <% } %>
                                                        <% if (isAdminU) { %>
                                                            <form action="/events/<%= event._id %>?_method=DELETE"
                                                                method="POST" class="d-inline"
                                                                onsubmit="return confirm('Delete this event and all its registrations?')">
                                                                <button class="btn btn-sm btn-outline-danger">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </form>
                                                            <% } %>
                                        </td>
                                    </tr>
                                    <% }); %>
                        </tbody>
                    </table>
                    <% } %>
        </div>
    </div>

    <!-- #8 Pagination -->
    <% if (totalPages> 1) { %>
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link"
                        href="/events?page=<%= currentPage - 1 %>&search=<%= search %>&venue=<%= venue %>">
                        &laquo; Prev
                    </a>
                </li>
                <% for (let p=1; p <=totalPages; p++) { %>
                    <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                        <a class="page-link" href="/events?page=<%= p %>&search=<%= search %>&venue=<%= venue %>">
                            <%= p %>
                        </a>
                    </li>
                    <% } %>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link"
                                href="/events?page=<%= currentPage + 1 %>&search=<%= search %>&venue=<%= venue %>">
                                Next &raquo;
                            </a>
                        </li>
            </ul>
        </nav>
        <% } %>

            <%- include('../partials/footer') %>