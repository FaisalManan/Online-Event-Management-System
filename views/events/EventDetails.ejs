<%- include('../partials/header') %>

    <% const isPast=new Date(event.eventDate) < new Date(); %>

        <div class="row">
            <!-- Event Info -->
            <div class="col-md-7">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-calendar-event me-2"></i>
                            <%= event.eventName %>
                                <% if (isPast) { %>
                                    <span class="badge bg-secondary ms-2 fs-6">Past</span>
                                    <% } %>
                        </h5>
                        <% if (currentUser) { %>
                            <% const isAdminUser=currentUser.role==='Admin' ; const
                                isOrganizerUser=currentUser.role==='Organizer' ; const isOwner=event.organizer &&
                                event.organizer._id.toString()===currentUser._id.toString(); %>
                                <div class="d-flex gap-2">
                                    <% if (isAdminUser || (isOrganizerUser && isOwner)) { %>
                                        <a href="/events/<%= event._id %>/edit" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <% } %>
                                            <% if (isAdminUser) { %>
                                                <form action="/events/<%= event._id %>?_method=DELETE" method="POST"
                                                    onsubmit="return confirm('Delete this event and all its registrations?')">
                                                    <button class="btn btn-sm btn-danger">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </button>
                                                </form>
                                                <% } %>
                                </div>
                                <% } %>
                    </div>

                    <!-- #10 – past event warning -->
                    <% if (isPast) { %>
                        <div class="alert alert-warning mb-0 rounded-0 past-event-warning">
                            <i class="bi bi-clock-history me-1"></i>
                            This event has already taken place (<%= new
                                Date(event.eventDate).toLocaleDateString('en-US', { dateStyle: 'medium' }) %>).
                        </div>
                        <% } %>

                            <div class="card-body">
                                <table class="table table-borderless mb-0">
                                    <tr>
                                        <th width="160">📅 Date</th>
                                        <td>
                                            <%= new Date(event.eventDate).toLocaleString('en-US', { dateStyle: 'full' ,
                                                timeStyle: 'short' }) %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>📍 Venue</th>
                                        <td>
                                            <%= event.venue %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>🧑‍💼 Organizer</th>
                                        <td>
                                            <%= event.organizer ? event.organizer.username : 'N/A' %>
                                                <% if (event.organizer && event.organizer.email) { %>
                                                    <small class="text-muted">(<%= event.organizer.email %>)</small>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>📝 Description</th>
                                        <td>
                                            <%= event.description || '—' %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>🗓 Created</th>
                                        <td>
                                            <%= new Date(event.createdDate).toLocaleDateString('en-US', {
                                                dateStyle: 'medium' }) %>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                </div>
            </div>

            <!-- Quick Register -->
            <div class="col-md-5">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0"><i class="bi bi-person-plus me-2"></i>Registration</h6>
                    </div>
                    <div class="card-body">
                        <% if (!currentUser) { %>
                            <a href="/login" class="btn btn-outline-success w-100">Login to Register</a>

                            <% } else if (currentUser.role==='Participant' ) { %>

                                <% if (isPast) { %>
                                    <!-- #10 – block registration for past events -->
                                    <div class="alert alert-secondary mb-0 small">
                                        <i class="bi bi-slash-circle me-1"></i>Registration is closed — this event has
                                        already passed.
                                    </div>

                                    <% } else if (alreadyRegistered) { %>
                                        <!-- #2 – already registered, show cancel button -->
                                        <div class="alert alert-success mb-3 already-registered-badge">
                                            <i class="bi bi-check-circle-fill me-1"></i> You are registered for this
                                            event.
                                        </div>
                                        <form action="/registrations/<%= alreadyRegistered._id %>?_method=DELETE"
                                            method="POST"
                                            onsubmit="return confirm('Cancel your registration for this event?')">
                                            <button class="btn btn-outline-danger w-100">
                                                <i class="bi bi-x-circle me-1"></i>Cancel My Registration
                                            </button>
                                        </form>

                                        <% } else { %>
                                            <!-- Normal register button -->
                                            <form action="/registrations" method="POST">
                                                <input type="hidden" name="event" value="<%= event._id %>" />
                                                <input type="hidden" name="participant"
                                                    value="<%= currentUser._id %>" />
                                                <button type="submit" class="btn btn-success w-100">
                                                    <i class="bi bi-check-circle me-1"></i>Register Me for This Event
                                                </button>
                                            </form>
                                            <% } %>

                                                <% } else { %>
                                                    <p class="text-muted mb-0 small">
                                                        Organizers and Admins manage registrations via the
                                                        <a href="/registrations/new">Registrations</a> page.
                                                    </p>
                                                    <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Registrations table -->
        <div class="card shadow-sm">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <span class="fw-semibold">
                    <i class="bi bi-people me-2"></i>Registrations (<%= registrations.length %>)
                </span>
                <% if (currentUser && (currentUser.role==='Organizer' || currentUser.role==='Admin' )) { %>
                    <a href="/registrations/new" class="btn btn-sm btn-primary">+ Add Registration</a>
                    <% } %>
            </div>
            <div class="card-body p-0">
                <% if (registrations.length===0) { %>
                    <p class="text-muted p-3 mb-0">No registrations yet.</p>
                    <% } else { %>
                        <table class="table table-hover table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Participant</th>
                                    <th>Email</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% registrations.forEach((r, i)=> { %>
                                    <tr>
                                        <td>
                                            <%= i + 1 %>
                                        </td>
                                        <td>
                                            <%= r.participant ? r.participant.username : 'N/A' %>
                                        </td>
                                        <td>
                                            <%= r.participant ? r.participant.email : '—' %>
                                        </td>
                                        <td>
                                            <%= new Date(r.registrationDate).toLocaleDateString('en-US', {
                                                dateStyle: 'medium' }) %>
                                        </td>
                                        <td>
                                            <span
                                                class="badge bg-<%= r.status === 'Approved' ? 'success' : r.status === 'Rejected' ? 'danger' : 'warning text-dark' %>">
                                                <%= r.status %>
                                            </span>
                                        </td>
                                    </tr>
                                    <% }); %>
                            </tbody>
                        </table>
                        <% } %>
            </div>
        </div>

        <div class="mt-3">
            <a href="/events" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to Events
            </a>
        </div>

        <%- include('../partials/footer') %>