<%- include('partials/header') %>

    <h2 class="mb-4">
        <i class="bi bi-speedometer2 me-2"></i>Dashboard
        <% if (currentUser.role==='Organizer' ) { %>
            <small class="fs-6 text-muted fw-normal ms-2"></small>
            <% } %>
    </h2>

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">

        <!-- Card 1: Events -->
        <div class="col-md-4">
            <div class="card text-white bg-primary shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-calendar-event fs-1"></i>
                    <div>
                        <div class="fs-2 fw-bold">
                            <%= totalEvents %>
                        </div>
                        <div>
                            <%= currentUser.role==='Organizer' ? 'Your Events' : 'Total Events' %>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-primary border-0">
                    <a href="/events" class="text-white text-decoration-none small">View all events →</a>
                </div>
            </div>
        </div>

        <!-- Card 2: Registrations (swapped here) -->
        <div class="col-md-4">
            <div class="card text-white bg-warning shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-ticket-perforated fs-1"></i>
                    <div>
                        <div class="fs-2 fw-bold">
                            <%= totalRegistrations %>
                        </div>
                        <div>
                            <%= currentUser.role==='Organizer' ? 'Registrations on Your Events' : 'Total Registrations'
                                %>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-warning border-0">
                    <a href="/registrations" class="text-white text-decoration-none small">View registrations →</a>
                </div>
            </div>
        </div>

        <!-- Card 3: Registered Users (swapped here) — hidden from Participants -->
        <div class="col-md-4">
            <% if (currentUser.role !=='Participant' ) { %>
                <div class="card text-white bg-success shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <i class="bi bi-people fs-1"></i>
                        <div>
                            <div class="fs-2 fw-bold">
                                <%= totalUsers %>
                            </div>
                            <div>Registered Users</div>
                        </div>
                    </div>
                    <% if (currentUser.role==='Admin' ) { %>
                        <div class="card-footer bg-success border-0">
                            <a href="/users" class="text-white text-decoration-none small">Manage users →</a>
                        </div>
                        <% } %>
                </div>
                <% } %>
        </div>

    </div><!-- /.row stats -->

    <!-- Quick Actions -->
    <div class="row mb-5">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold bg-light">Quick Actions</div>
                <div class="card-body d-flex flex-wrap gap-2">
                    <% if (currentUser.role==='Organizer' || currentUser.role==='Admin' ) { %>
                        <a href="/events/new" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-1"></i>New Event
                        </a>
                        <a href="/registrations/new" class="btn btn-outline-primary">
                            <i class="bi bi-person-plus me-1"></i>New Registration
                        </a>
                        <% } %>
                            <a href="/events" class="btn btn-outline-secondary">
                                <i class="bi bi-list-ul me-1"></i>All Events
                            </a>
                            <% if (currentUser.role==='Admin' ) { %>
                                <a href="/users" class="btn btn-outline-danger">
                                    <i class="bi bi-people me-1"></i>Manage Users
                                </a>
                                <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Events -->
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center bg-light">
            <span class="fw-semibold"><i class="bi bi-clock-history me-2"></i>Recent Events</span>
            <a href="/events" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
        <div class="card-body p-0">
            <% if (recentEvents.length===0) { %>
                <% if (currentUser.role==='Organizer' || currentUser.role==='Admin' ) { %>
                    <p class="text-muted p-3 mb-0">No events yet. <a href="/events/new">Create one</a>.</p>
                    <% } else { %>
                        <p class="text-muted p-3 mb-0">No events yet.</p>
                        <% } %>
                            <% } else { %>
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Event Name</th>
                                            <th>Date</th>
                                            <th>Venue</th>
                                            <th>Organizer</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% recentEvents.forEach(event=> { %>
                                            <tr>
                                                <td>
                                                    <%= event.eventName %>
                                                </td>
                                                <td>
                                                    <%= new Date(event.eventDate).toLocaleDateString('en-US', {
                                                        dateStyle: 'medium' }) %>
                                                </td>
                                                <td>
                                                    <%= event.venue %>
                                                </td>
                                                <td>
                                                    <%= event.organizer ? event.organizer.username : 'N/A' %>
                                                </td>
                                                <td>
                                                    <a href="/events/<%= event._id %>"
                                                        class="btn btn-sm btn-outline-primary">View</a>
                                                </td>
                                            </tr>
                                            <% }); %>
                                    </tbody>
                                </table>
                                <% } %>
        </div>
    </div>

    <%- include('partials/footer') %>