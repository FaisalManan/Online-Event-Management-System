                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPath === '/register' ? 'active fw-semibold' : '' %>"
                                href="/register">Register</a>
                        </li>
                        <% } %>
            </ul>
        </div>
    </div>
