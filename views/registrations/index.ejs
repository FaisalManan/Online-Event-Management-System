<%- include('../partials/header') %>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-ticket-perforated me-2"></i>
            <% if (currentUser.role==='Participant' ) { %>My Registrations<% } else { %>All Registrations<% } %>
        </h2>
        <% if (currentUser.role==='Organizer' || currentUser.role==='Admin' ) { %>
            <a href="/registrations/new" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Add Registration
            </a>
            <% } %>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <% if (registrations.length===0) { %>
                <p class="text-muted p-4 mb-0">No registrations found.</p>
                <% } else { %>
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-primary">
                            <tr>
                                <th>#</th>
                                <th>Participant</th>
                                <th>Event</th>
                                <th>Event Date</th>
                                <th>Registered On</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% registrations.forEach((reg, i)=> { %>
                                <tr>
                                    <td>
                                        <%= (currentPage - 1) * limit + i + 1 %>
                                    </td>
                                    <td>
                                        <%= reg.participant ? reg.participant.username : 'N/A' %>
                                    </td>
                                    <td>
                                        <% if (reg.event) { %>
                                            <a href="/events/<%= reg.event._id %>">
                                                <%= reg.event.eventName %>
                                            </a>
                                            <% } else { %>N/A<% } %>
                                    </td>
                                    <td>
                                        <% if (reg.event) { %>
                                            <%= new Date(reg.event.eventDate).toLocaleDateString('en-US', {
                                                dateStyle: 'medium' }) %>
                                                <% } else { %>—<% } %>
                                    </td>
                                    <td>
                                        <%= new Date(reg.registrationDate).toLocaleDateString('en-US', {
                                            dateStyle: 'medium' }) %>
                                    </td>
                                    <td>
                                        <span
                                            class="badge bg-<%= reg.status === 'Approved' ? 'success' : reg.status === 'Rejected' ? 'danger' : 'warning text-dark' %>">
                                            <%= reg.status %>
                                        </span>
                                    </td>
                                    <td>
                                        <!-- Organizer & Admin: edit button -->
                                        <% if (currentUser.role==='Organizer' || currentUser.role==='Admin' ) { %>
                                            <a href="/registrations/<%= reg._id %>/edit"
                                                class="btn btn-sm btn-outline-warning me-1">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <% } %>

                                                <!-- Admin: delete button -->
                                                <% if (currentUser.role==='Admin' ) { %>
                                                    <form action="/registrations/<%= reg._id %>?_method=DELETE"
                                                        method="POST" class="d-inline"
                                                        onsubmit="return confirm('Delete this registration?')">
                                                        <button class="btn btn-sm btn-outline-danger">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                    <% } %>

                                                        <!-- #9 Participant: cancel own registration -->
                                                        <% if (currentUser.role==='Participant' ) { %>
                                                            <form action="/registrations/<%= reg._id %>?_method=DELETE"
                                                                method="POST" class="d-inline"
                                                                onsubmit="return confirm('Cancel your registration for this event?')">
                                                                <button class="btn btn-sm btn-outline-danger">
                                                                    <i class="bi bi-x-circle me-1"></i>Cancel
                                                                </button>
                                                            </form>
                                                            <% } %>
                                    </td>
                                </tr>
                                <% }); %>
                        </tbody>
                    </table>
                    <% } %>
        </div>
    </div>

    <!-- #8 Pagination -->
    <% if (totalPages> 1) { %>
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="/registrations?page=<%= currentPage - 1 %>">&laquo; Prev</a>
                </li>
                <% for (let p=1; p <=totalPages; p++) { %>
                    <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                        <a class="page-link" href="/registrations?page=<%= p %>">
                            <%= p %>
                        </a>
                    </li>
                    <% } %>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link" href="/registrations?page=<%= currentPage + 1 %>">Next &raquo;</a>
                        </li>
            </ul>
        </nav>
        <% } %>

            <%- include('../partials/footer') %>